# ---------------------------------------------------------------------------
# Band platform connection (same for every agent)
# ---------------------------------------------------------------------------
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# ---------------------------------------------------------------------------
# Per-agent credentials. Create four agents in your Band workspace and paste
# each agent's id + api key here. Names must match common/pipeline.py.
# ---------------------------------------------------------------------------
BAND_AGENT1_ID=
BAND_AGENT1_KEY=
BAND_AGENT2_ID=
BAND_AGENT2_KEY=
BAND_AGENT3_ID=
BAND_AGENT3_KEY=
BAND_AGENT4_ID=
BAND_AGENT4_KEY=

# ---------------------------------------------------------------------------
# Laravel payroll API (Day 1 layer). PAYROLL_API_KEY must equal BAND_API_KEY
# in the Laravel .env.
# ---------------------------------------------------------------------------
PAYROLL_API_URL=https://payroll.carlssonstudio.com
PAYROLL_API_KEY=

# ---------------------------------------------------------------------------
# LLM providers (OpenAI-compatible). Optional: agents fall back to deterministic
# output if a key is missing. Agent 3 (compliance) uses AI/ML API; Agent 4
# (reports) uses Featherless.
# ---------------------------------------------------------------------------
AIMLAPI_API_KEY=
# AIMLAPI_MODEL=gpt-4o-mini
FEATHERLESS_API_KEY=
# FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Regional minimum wage used by the compliance agent (Jakarta UMR default).
# UMR_MINIMUM=4900000
